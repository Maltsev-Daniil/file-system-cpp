{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "binaryDir": "${sourceDir}/cmake-build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "coverage",
            "displayName": "Debug with Coverage",
            "binaryDir": "${sourceDir}/cmake-build-debug-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "--coverage -g -O0",
                "CMAKE_EXE_LINKER_FLAGS": "--coverage"
            }
        },
        {
            "name": "tsan",
            "displayName": "ThreadSanitizer (Clang)",
            "binaryDir": "${sourceDir}/cmake-build-tsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-fsanitize=thread -g -O1",
                "ENABLE_TSAN": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release Build with flags",
            "binaryDir": "${sourceDir}/cmake-build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "tsan",
            "configurePreset": "tsan"
        },
        {
            "name": "release",
            "configurePreset": "release"
        }
    ]
}

